# Cloudflare R2 Storage
R2_PUBLIC_URL=https://your-r2-bucket.example.com
NEXT_PUBLIC_R2_URL=https://your-r2-bucket.example.com
# Legacy alias kept for compatibility
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-bucket.example.com
R2_VARIANTS_PREFIX=variants

# CLI Upload Settings (optional)
CONCURRENCY=4
VERBOSE=false

# AI Analysis (optional)
GEN_AI_ANALYSIS=false
OPENAI_API_KEY=
GROQ_API_KEY=

# Geocoding (optional)
NOMINATIM_EMAIL=

# Mapbox (optional)
NEXT_PUBLIC_MAPBOX_TOKEN=
