{
  "name": "photos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "portless photography pnpm --filter web dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "knip": "knip",
    "prepare": "husky",
    "infra:deploy": "bun alchemy.run.ts",
    "infra:destroy": "bun alchemy.run.ts --destroy"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "alchemy": "^0.83.1",
    "husky": "^9.1.7",
    "knip": "^5.77.1",
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ],
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  }
}
