{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreWorkspaces": ["packages/typescript-config"],
  "workspaces": {
    "apps/web": {
      "entry": ["app/**/*.{ts,tsx}", "cli/*.ts", "lib/imageLoader.ts"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["**/*.d.ts"],
      "ignoreDependencies": ["tw-animate-css", "tailwindcss"]
    },
    "packages/eslint-config": {
      "entry": ["*.mjs"],
      "project": ["*.mjs"]
    }
  }
}
